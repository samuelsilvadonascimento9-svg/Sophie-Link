# Esconder listagem de diretórios (Segurança)
Options -Indexes

# Ocultar assinatura do servidor
ServerSignature Off

# Configurar página de erro 404 personalizada
ErrorDocument 404 /public/404.php

# Prevenir acesso direto ao arquivo .env e arquivos de log
<FilesMatch "^\.env|app\.log$">
    Require all denied
</FilesMatch>

# Bloquear acesso direto às pastas do Core (caso o Rewrite falhe)
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bloqueia acesso direto via navegador às pastas do Core
    RewriteRule ^(includes|database|backend|scripts) - [F,L]

    # Redireciona tudo silenciosamente para a pasta public/
    RewriteCond %{REQUEST_URI} !public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# ==============================================================================
# PERFORMANCE E CACHE DE NAVEGADOR (ITEM 20)
# ==============================================================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    
    # Imagens, CSS, JS e Fontes recebem cache agressivo (1 ano)
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType application/x-javascript "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    
    # HTML e PHP não devem ser cacheados (sempre validar com servidor)
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
    # Proteger contra Clickjacking e Sniffing de MIME
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    
    # Para arquivos cacheados fortemente, definir Cache-Control explicitamente
    <FilesMatch "\.(ico|pdf|flv|jpg|jpeg|png|gif|svg|js|css|swf|woff|woff2)$">
        Header set Cache-Control "max-age=31536000, public"
    </FilesMatch>
    
    # Prevenir cache em páginas dinâmicas
    <FilesMatch "\.(php|html|htm)$">
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
    </FilesMatch>
</IfModule>

# Compressão GZIP para performance
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>
